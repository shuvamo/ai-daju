# ── Auto-detect text files & normalize line endings ──
* text=auto

# ── Source code — enforce LF ──────────────────────────
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env   text eol=lf
*.sh    text eol=lf

# ── Windows-specific ───────────────────────────────────
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# ── Binary files — do not modify ──────────────────────
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.zip   binary
*.tar   binary
*.gz    binary
*.pdf   binary
